# =============================================================================
# TrendDNA — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to Git. Only .env.example is tracked.
# =============================================================================

# Django environment: "development" or "production"
DJANGO_ENV=development

# Secret key — generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-only-change-in-production

# Debug mode (only True in development)
DEBUG=True

# Comma-separated allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection URL (used in production)
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://trenddna:password@localhost:5432/trenddna

# CORS — comma-separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# YouTube Data API v3 key (optional — Reddit works without this)
# Get a free key at: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in the API library
YOUTUBE_API_KEY=

# Reddit OAuth (optional — improves reliability vs public API)
# Register a free "script" app at: https://www.reddit.com/prefs/apps
# Select "script" type, use http://localhost:8000 as redirect URI
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
